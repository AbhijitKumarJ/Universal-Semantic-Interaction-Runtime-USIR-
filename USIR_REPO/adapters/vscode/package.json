{
  "name": "@usir/vscode-adapter",
  "version": "0.1.0",
  "description": "VS Code adapter — bridges VS Code Extension API to USIR SemanticSnapshot",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run",
