    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@usir/protocol": "workspace:*",
    "@usir/runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/vscode": "^1.85.0"
  }
}
