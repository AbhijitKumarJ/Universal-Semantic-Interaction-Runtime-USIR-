{
  "name": "@usir/registry-client",
  "version": "0.1.0",
  "description": "Client SDK for the USIR Capability Registry",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/registry-client.d.ts",
      "import": "./dist/registry-client.js"
    },
    "./cache": {
      "types": "./dist/local-cache.d.ts",
      "import": "./dist/local-cache.js"
    },
    "./sync": {
      "types": "./dist/sync-protocol.d.ts",
      "import": "./dist/sync-protocol.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@usir/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  }
}
