{
  "name": "@usir/protocol",
  "version": "0.1.0",
  "description": "Universal Interaction Language (UIL) — Semantic entities, intents, snapshots, and the provenance layer",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "import": "./dist/entities/index.js"
    },
    "./intents": {
      "types": "./dist/intents/index.d.ts",
      "import": "./dist/intents/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot/index.d.ts",
      "import": "./dist/snapshot/index.js"
    },
    "./waypoint": {
      "types": "./dist/waypoint/index.d.ts",
      "import": "./dist/waypoint/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./provenance": {
      "types": "./dist/provenance/index.d.ts",
      "import": "./dist/provenance/index.js"
    },
    "./capability": {
      "types": "./dist/capability/index.d.ts",
      "import": "./dist/capability/index.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.0.0"
  }
}
