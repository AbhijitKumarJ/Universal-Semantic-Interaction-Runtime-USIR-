{
  "name": "@usir/federation",
  "version": "0.1.0",
  "description": "Federated Runtime — WebRTC P2P, CRDT SemanticGraph sync, cross-runtime provenance, and L8 collaboration intents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./peer": {
      "types": "./dist/peer/index.d.ts",
      "import": "./dist/peer/index.js"
    },
    "./message": {
      "types": "./dist/message/index.d.ts",
      "import": "./dist/message/index.js"
    },
    "./topology": {
      "types": "./dist/topology/index.d.ts",
      "import": "./dist/topology/index.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot/index.d.ts",
      "import": "./dist/snapshot/index.js"
    },
    "./provenance": {
      "types": "./dist/provenance/index.d.ts",
      "import": "./dist/provenance/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    },
    "./signaling": {
      "types": "./dist/signaling/index.d.ts",
      "import": "./dist/signaling/index.js"
    },
    "./connection": {
      "types": "./dist/connection/index.d.ts",
      "import": "./dist/connection/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.js"
    },
    "./collaboration": {
      "types": "./dist/collaboration/index.d.ts",
      "import": "./dist/collaboration/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@usir/protocol": "workspace:*",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  }
}
