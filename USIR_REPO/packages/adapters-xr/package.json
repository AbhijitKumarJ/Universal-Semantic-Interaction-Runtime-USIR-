{
  "name": "@usir/adapters-xr",
  "version": "0.1.0",
  "description": "XR adapters — Unity bridge, spatial anchors, and XR input via the Tool interface",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./unity-bridge": {
      "types": "./dist/unity-bridge-adapter.d.ts",
      "import": "./dist/unity-bridge-adapter.js"
    },
    "./spatial-anchor": {
      "types": "./dist/spatial-anchor-adapter.d.ts",
      "import": "./dist/spatial-anchor-adapter.js"
    },
    "./xr-input": {
      "types": "./dist/xr-input-adapter.d.ts",
      "import": "./dist/xr-input-adapter.js"
    },
    "./factory": {
      "types": "./dist/factory.d.ts",
      "import": "./dist/factory.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  }
}
